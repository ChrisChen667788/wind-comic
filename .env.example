# ============================================================================
# Wind Comic — Environment Configuration
# ============================================================================
# Copy this file to `.env.local` and fill in your provider keys.
# Wind Comic is provider-agnostic — every key below has a sensible fallback,
# and you only need to fill in keys for the providers you actually use.
#
# Minimum viable config (cheapest, English/Chinese both work):
#   1) OPENAI_API_KEY           — for script generation (any OpenAI-compatible)
#   2) MINIMAX_API_KEY          — for image + video + TTS (Chinese-friendly)
#
# Recommended config (best quality, cinematic output):
#   1) OPENAI_API_KEY           — Claude/GPT-4 via vectorengine or direct
#   2) MJ_API_KEY               — Midjourney via vectorengine for storyboards
#   3) MINIMAX_API_KEY          — for video + TTS
#   4) QINGYUNTOP_API_KEY       — for Sora-2 / Veo-3 fallback video
# ============================================================================


# ─── 1. LLM (Script + Director + Polish) ───────────────────────────────────
# Any OpenAI-compatible endpoint. Default points to OpenAI;
# override OPENAI_BASE_URL to use proxies (vectorengine.ai, openrouter, etc.)
# OPENAI_CREATIVE_MODEL is used for screenwriting/critique (higher quality);
# OPENAI_MODEL is used for routine planning (faster/cheaper).
OPENAI_API_KEY=your_openai_or_proxy_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_CREATIVE_MODEL=claude-sonnet-4-20250514

# ─── 2. Image generation ───────────────────────────────────────────────────
# Midjourney via aggregator (best quality for storyboards + character refs)
# Set MJ_BASE_URL to any /mj/submit/imagine compatible aggregator.
MJ_API_KEY=
MJ_BASE_URL=https://api.vectorengine.ai

# Banana.dev (legacy alias for MJ_API_KEY — still read for backward compat)
BANANA_API_KEY=
BANANA_MODEL_KEY=

# ─── 3. Video generation ───────────────────────────────────────────────────
# Minimax (recommended primary — cheap, fast, Chinese voice support)
# Models: T2V=MiniMax-Hailuo-2.3 / I2V=I2V-01 / TTS=speech-2.8-hd / Music=music-2.6
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimaxi.com

# v2.12 兜底:Hailuo-2.3-Fast (768P) 是 Minimax 的低质快速版,日额度独立于标准 Hailuo-2.3。
# orchestrator Pass-B 链路:Veo-T2V → Hailuo-2.3 → Hailuo-Fast → Kling → Ken Burns 静帧。
# 标准 Hailuo 用满后,先用同一家的 Fast(成本/响应/失败率更可控),再换 Kling,
# 真视频全失败才掉到 Ken Burns animatic。模型名可改:
MINIMAX_FAST_VIDEO_MODEL=MiniMax-Hailuo-2.3-Fast

# v2.12 Sprint C.4: TTS 默认模型 — 与 minimax.service.ts 的 voiceover 模型对齐。
# 默认 speech-2.8-hd(质量最佳);旧版可填 speech-02 兜底。
MINIMAX_TTS_MODEL=speech-2.8-hd

# Vidu (alternative T2V)
VIDU_API_KEY=
VIDU_BASE_URL=https://api.vidu.ai

# Kling (alternative T2V/I2V)
KELING_API_KEY=
KELING_BASE_URL=https://api.klingai.com

# Veo / Sora via qingyuntop (cinematic upgrade for finals)
# Format: 'unified' uses POST /v1/video/create + GET /v1/video/query
#         'openai'  uses POST /v1/videos       + GET /v1/videos/<id>
VEO_API_KEY=
VEO_BASE_URL=https://api.qingyuntop.top
VEO_MODEL=sora-2
VEO_API_FORMAT=openai
VEO_FALLBACK_MODELS=veo3.1-fast,veo3-fast

# qingyuntop unified gateway (shared key, used as fallback for video + image)
QINGYUNTOP_API_KEY=
QINGYUNTOP_BASE_URL=https://api.qingyuntop.top

# ─── 4. Advanced consistency engines (optional) ────────────────────────────
# fal.ai for FLUX Kontext (state-of-the-art reference-image consistency)
FAL_KEY=

# Local ComfyUI (zero per-image cost, requires self-hosted node)
COMFYUI_URL=http://localhost:8188
COMFYUI_ENABLED=false

# ─── 5. XVERSE-Ent open-source MoE screenwriter (optional) ─────────────────
# Self-hosted alternative to OpenAI for the writer agent.
# Run with vLLM: python -m vllm.entrypoints.openai.api_server \
#                  --model xverse/XVERSE-Ent-A5.7B --trust-remote-code
# See: https://github.com/xverse-ai/XVERSE-Ent
XVERSE_ENABLED=false
XVERSE_FALLBACK=true
XVERSE_BASE_URL=http://localhost:8000/v1
XVERSE_API_KEY=
XVERSE_MODEL=xverse/XVERSE-Ent-A5.7B
XVERSE_FAST_MODEL=xverse/XVERSE-Ent-A4.2B
XVERSE_TEMPERATURE=0.85
XVERSE_TOP_P=0.9
XVERSE_MAX_TOKENS=6144
XVERSE_TIMEOUT=180000

# ─── 6. App secrets ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_to_a_random_32_char_string

# ─── 7. Telemetry (optional) ───────────────────────────────────────────────
# Sentry DSN for error tracking (leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=
